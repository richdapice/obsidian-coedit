{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "coedit-sync",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "durable_objects": {
    "bindings": [{ "name": "YDocServer", "class_name": "YDocServer" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["YDocServer"] }],
  "r2_buckets": [{ "binding": "BLOBS", "bucket_name": "coedit-blobs" }],
  "observability": { "enabled": true }
}
